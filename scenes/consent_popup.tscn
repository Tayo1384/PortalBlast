offset_top = 75.0
offset_right = 575.0
offset_bottom = 370.0
theme_override_colors/font_color = Color(0.85, 0.82, 0.76, 0.9)
theme_override_font_sizes/font_size = 17
text = "Folk Blast affiche des publicités pour rester gratuit.

En acceptant, vous autorisez Google AdMob à collecter des identifiants publicitaires pour afficher des annonces adaptées à vos centres d'intérêt.

En refusant, aucune publicité ne sera affichée.

Vous pouvez changer d'avis à tout moment dans les paramètres."
autowrap_mode = 3

